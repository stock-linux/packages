name: yelp-xsl
version: 42.0
description: The Yelp XSL package contains XSL stylesheets that are used by the Yelp help browser to format Docbook and Mallard documents.
url: https://www.gnome.org
source: https://download.gnome.org/sources/yelp-xsl/42/yelp-xsl-42.0.tar.xz
makedeps: libxslt itstool
rundeps: libxslt itstool
build(

./configure --prefix=/usr

make DESTDIR=$PKG install

)
